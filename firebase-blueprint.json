{
  "entities": {
    "leads": {
      "title": "Loan Lead",
      "description": "A loan application lead generated by a user.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the applicant" },
        "phone": { "type": "string", "description": "Contact phone number" },
        "email": { "type": "string", "description": "Email address" },
        "loanType": { "type": "string", "description": "Type of loan requested", "enum": ["home", "personal", "business", "lap", "car", "gold"] },
        "loanAmount": { "type": "number", "description": "Requested loan amount in INR" },
        "monthlyIncome": { "type": "number", "description": "Applicant's net monthly income" },
        "employmentType": { "type": "string", "description": "Employment status", "enum": ["salaried", "self-employed"] },
        "city": { "type": "string", "description": "Applicant's current city" },
        "ownerId": { "type": "string", "description": "Firebase Auth UID of the owner" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Server timestamp of creation" },
        "status": { "type": "string", "description": "Current status of the application", "enum": ["received", "processing", "approved", "rejected"] }
      },
      "required": ["name", "phone", "loanType", "loanAmount", "ownerId", "createdAt", "status"]
    },
    "advisor_logs": {
      "title": "AI Advisor Log",
      "description": "Logs of interactions with the AI Loan Advisor.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Firebase Auth UID of the user" },
        "query": { "type": "string", "description": "The user's query" },
        "response": { "type": "string", "description": "The AI's response" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp" }
      },
      "required": ["userId", "query", "response", "createdAt"]
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "leads",
      "description": "Collection of loan applications."
    },
    "/advisor_logs/{logId}": {
      "schema": "advisor_logs",
      "description": "History of AI advisor interactions."
    }
  }
}
